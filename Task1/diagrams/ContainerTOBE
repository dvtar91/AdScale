Rel(accountService, accountDb, "Owns identity/account data", "SQL")
Rel(financeService, financeDb, "Owns ledger and balances", "SQL")
Rel(creativeService, creativeDb, "Owns creative metadata and moderation state", "SQL/Object API")

Rel(campaignService, eventBus, "Publishes campaign_changed/bid_changed/status_changed", "Kafka API")
Rel(financeService, eventBus, "Publishes balance_changed/payment_confirmed", "Kafka API")
Rel(creativeService, eventBus, "Publishes creative_changed/moderation_changed", "Kafka API")
