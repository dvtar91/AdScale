@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_LEFT_RIGHT()

title C4 Container Diagram — AdScale Target Architecture (TO-BE, 1 year)

' ====================== Акторы и внешние системы ======================
Person(advertiser, "Рекламодатель", "Создаёт кампании, управляет ставками, бюджетами и смотрит отчётность")
Person_Ext(endUser, "Пользователь сайта/приложения", "Просматривает рекламу и кликает по баннерам")

System_Ext(dspPartner, "DSP-партнёры", "Отправляют bid requests и получают bid responses по OpenRTB")
System_Ext(paymentGateway, "Платёжный шлюз", "Обработка пополнения рекламных бюджетов")
System_Ext(notificationProvider, "Email/SMS/Push Provider", "Уведомления рекламодателей о платежах, лимитах и статусах кампаний")

' ====================== Edge / API слой ======================
System_Boundary(edge, "Edge / API Layer") {

    Container(apiGateway, "API Gateway", "Kong / NGINX / Envoy", "Единая точка входа для Dashboard API: TLS termination, auth, rate limiting, routing")

    Container(bidGateway, "DSP Bid Gateway", "Go / C++", "Высокопроизводительный входной шлюз для bid requests: OpenRTB validation, partner routing, timeout budget, rate limiting") <<Critical Path>>

    Container(cdn, "CDN / Static Assets", "CDN", "Раздача статических ресурсов рекламного кабинета и JS/assets")
}

' ====================== RTB Runtime ======================
System_Boundary(rtb, "RTB Runtime Services") {

    Container(adServerSvc, "Ad Serving Service", "Go / C++", "Определение пользователя, таргетинг, подбор кандидатов, подготовка запроса на аукцион") <<Critical Path>>

    Container(auctionSvc, "Auction Service", "C++ / Go", "Расчёт победителя RTB-аукциона: ставки, правила, pacing, budget checks, bid response decision") <<Critical Path>>

    Container(deliverySvc, "Delivery Service", "Node.js / Go", "Формирование креатива, HTML/JS/VAST/native response, трекинговых ссылок")

    Container(userProfileSvc, "User Profile Service", "Go", "Сегменты, признаки пользователя, frequency capping, user matching")

    Container(budgetGuardSvc, "Budget Guard Service", "Go", "Быстрая проверка доступности бюджета и лимитов для hot path без финансовых транзакций")
}

' ====================== Campaign / Advertiser domain ======================
System_Boundary(campaign, "Campaign Management Domain") {

    Container(campaignSvc, "Campaign Service", "Go / Node.js", "CRUD кампаний, таргетинг, статусы, расписания, правила показа")

    Container(bidStrategySvc, "Bid Strategy Service", "Go / Python", "Управление ставками, стратегиями оптимизации, bid modifiers")

    Container(creativesSvc, "Creative Service", "Node.js / Go", "Управление креативами, модерация, версии, asset metadata")

    Container(dashboardBff, "Advertiser Dashboard BFF", "Node.js", "Backend-for-Frontend для рекламного кабинета: агрегация API, auth context, UI-specific endpoints")

    Container(spa, "Advertiser Dashboard SPA", "JavaScript / React", "Web UI рекламодателя")
}

' ====================== Event / Statistics domain ======================
System_Boundary(events, "Event & Statistics Domain") {

    Container(eventCollector, "Event Collector Service", "Go", "Приём событий показов, кликов, win/loss, auction result; быстрый ack и запись в Kafka") <<High Throughput>>

    Container(statsProcessor, "Statistics Processor", "Go / Flink / Kafka Streams", "Агрегация событий по кампаниям, креативам, DSP, времени")

    Container(billingEventsConsumer, "Billing Events Consumer", "Go", "Потребляет billable events и передаёт их в финансовый домен для списаний")

    Container(fraudDetectionSvc, "Fraud Detection Service", "Python / Go", "Асинхронная проверка подозрительных кликов/показов, скоринг fraud-событий")
}

' ====================== Finance / Billing domain ======================
System_Boundary(finance, "Finance & Billing Domain") {

    Container(financeSvc, "Finance Service", "Go", "Пополнения, балансы, ledger, invoices, корректные финансовые транзакции") <<Strong Consistency>>

    Container(billingSvc, "Billing Service", "Go", "Расчёт стоимости событий, списания по billable events, сверка расходов")

    Container(paymentSvc, "Payment Integration Service", "Go", "Интеграция с внешним payment gateway, webhooks, idempotency")
}

' ====================== Analytics / Reporting domain ======================
System_Boundary(analytics, "Analytics & Reporting Domain") {

    Container(reportingSvc, "Reporting Service", "Python / Go", "API отчётов для рекламодателей: кампании, показы, клики, CTR, spend, ROI")

    Container(analyticsProcessor, "Analytics Processor", "Flink / Spark / Python", "ETL/ELT обработка событий, построение витрин и долгосрочной аналитики")

    Container(realtimeMetricsSvc, "Realtime Metrics Service", "Go / Kafka Streams", "Near-real-time метрики для dashboard и operational monitoring")
}

' ====================== Platform / Infrastructure ======================
System_Boundary(platform, "Platform & Infrastructure") {

    Container(messageBroker, "Kafka Cluster", "Apache Kafka", "Event streaming: impressions, clicks, auction-results, billing-events, campaign-change-events") <<Event Backbone>>

    Container(redisCluster, "Redis Cluster", "Redis", "Low-latency cache для hot data: кампании, ставки, таргетинг, budget snapshots, user caps") <<Low Latency>>

    Container(configSvc, "Config / Feature Flag Service", "Unleash / LaunchDarkly / Custom", "Feature flags, canary, DSP traffic routing, kill switches")

    Container(serviceMesh, "Service Mesh", "Istio / Linkerd / Envoy", "mTLS, retries, circuit breakers, traffic splitting, observability")

    Container(observability, "Observability Stack", "Prometheus / Grafana / Loki / Tempo / Jaeger", "Метрики, логи, трассировка, SLA/SLO мониторинг")

    Container(schemaRegistry, "Schema Registry", "Confluent / Apicurio", "Контракты событий Kafka и совместимость схем")
}

' ====================== Databases / Storage ======================
System_Boundary(data, "Data Stores") {

    ContainerDb(campaignDb, "Campaign DB", "PostgreSQL HA", "Кампании, таргетинг, статусы, настройки показов")

    ContainerDb(strategyDb, "Bid Strategy DB", "PostgreSQL HA", "Ставки, стратегии, bid modifiers, правила оптимизации")

    ContainerDb(creativeDb, "Creative DB", "PostgreSQL HA", "Метаданные креативов, статусы модерации, версии")
    ContainerDb(objectStorage, "Creative Object Storage", "S3-compatible", "Изображения, видео, HTML/JS assets")

    ContainerDb(userProfileDb, "User Profile Store", "Cassandra / ScyllaDB / Redis", "Профили пользователей, сегменты, frequency capping")

    ContainerDb(financeDb, "Finance DB", "PostgreSQL HA", "Ledger, балансы, invoices, платежи, транзакции") <<Strong Consistency>>

    ContainerDb(statsDb, "Statistics Store", "ClickHouse", "Агрегированная статистика показов, кликов, win/loss, cost metrics")

    ContainerDb(analyticsDwh, "Analytics DWH", "ClickHouse / BigQuery / Snowflake", "Историческая аналитика, витрины данных, тяжёлые отчёты")

    ContainerDb(idempotencyDb, "Payment Idempotency Store", "PostgreSQL / Redis", "Idempotency keys, payment webhook state")
}

' ====================== Внешние связи ======================
Rel(advertiser, spa, "Работает с кабинетом", "HTTPS")
Rel(spa, cdn, "Загружает static assets", "HTTPS")
Rel(spa, apiGateway, "Dashboard API calls", "HTTPS / REST")
Rel(dspPartner, bidGateway, "Bid requests / bid responses", "HTTPS / OpenRTB")
Rel(endUser, deliverySvc, "Получает рекламу / кликает", "HTTPS")
Rel(paymentGateway, paymentSvc, "Payment webhooks / payment status", "HTTPS / REST")
Rel(paymentSvc, paymentGateway, "Create payment / refund / status check", "HTTPS / REST")
Rel(financeSvc, notificationProvider, "Уведомления о платежах, лимитах, счетах", "HTTPS / REST")

' ====================== Dashboard / API связи ======================
Rel(apiGateway, dashboardBff, "Routes advertiser API requests", "HTTPS / REST")
Rel(dashboardBff, campaignSvc, "Управление кампаниями", "gRPC / REST")
Rel(dashboardBff, bidStrategySvc, "Управление ставками и стратегиями", "gRPC / REST")
Rel(dashboardBff, creativesSvc, "Управление креативами", "gRPC / REST")
Rel(dashboardBff, financeSvc, "Балансы, счета, платежи", "gRPC / REST")
Rel(dashboardBff, reportingSvc, "Отчёты и аналитика", "gRPC / REST")

' ====================== RTB hot path ======================
Rel(bidGateway, adServerSvc, "Validated bid request", "gRPC / low-latency")
Rel(adServerSvc, userProfileSvc, "Получение сегментов и caps", "gRPC")
Rel(adServerSvc, auctionSvc, "Кандидаты и контекст аукциона", "gRPC / low-latency")
Rel(auctionSvc, budgetGuardSvc, "Fast budget / pacing check", "gRPC / cache-backed")
Rel(auctionSvc, deliverySvc, "Winner and creative context", "gRPC")
Rel(deliverySvc, bidGateway, "Bid response payload", "gRPC")
Rel(bidGateway, dspPartner, "Bid response", "HTTPS / OpenRTB")

' ====================== Cache usage ======================
Rel(adServerSvc, redisCluster, "Читает hot campaigns, targeting cache", "Redis")
Rel(auctionSvc, redisCluster, "Читает ставки, pacing, budget snapshots", "Redis")
Rel(budgetGuardSvc, redisCluster, "Budget snapshots / atomic counters", "Redis")
Rel(userProfileSvc, redisCluster, "Frequency caps / user cache", "Redis")
Rel(deliverySvc, redisCluster, "Creative metadata cache", "Redis")

' ====================== Events ======================
Rel(deliverySvc, eventCollector, "Impression / click tracking events", "HTTPS / async")
Rel(bidGateway, eventCollector, "Bid request / timeout / error events", "Async HTTP / UDP / gRPC")
Rel(auctionSvc, eventCollector, "Auction result events", "Async gRPC")
Rel(eventCollector, messageBroker, "Publishes raw events", "Kafka")

Rel(messageBroker, statsProcessor, "Consumes impressions/clicks/auction-results", "Kafka")
Rel(messageBroker, billingEventsConsumer, "Consumes billable events", "Kafka")
Rel(messageBroker, fraudDetectionSvc, "Consumes click/impression events", "Kafka")
Rel(messageBroker, analyticsProcessor, "Consumes event stream", "Kafka")
Rel(messageBroker, realtimeMetricsSvc, "Consumes operational and business events", "Kafka")

Rel(campaignSvc, messageBroker, "Publishes campaign-change-events", "Kafka")
Rel(bidStrategySvc, messageBroker, "Publishes bid-strategy-change-events", "Kafka")
Rel(creativesSvc, messageBroker, "Publishes creative-change-events", "Kafka")
Rel(financeSvc, messageBroker, "Publishes balance-change-events", "Kafka")
Rel(billingSvc, messageBroker, "Publishes billing-events", "Kafka")

