' RTB critical path
' =========================================================
Rel(rtbGateway, auctionService, "Normalized bid request with deadline", "gRPC")
Rel(auctionService, targetingService, "Evaluate targeting", "gRPC / low timeout")
Rel(auctionService, budgetService, "Reserve/check budget and pacing", "gRPC / low timeout")
Rel(auctionService, creativeService, "Get eligible creatives / metadata", "gRPC / low timeout")
Rel(auctionService, userProfileService, "Read segments / frequency cap", "gRPC / low timeout")
Rel(auctionService, responseBuilder, "Winner and response context", "gRPC")
Rel(responseBuilder, rtbGateway, "OpenRTB bid response", "gRPC")

' RTB reads from low-latency serving layer
Rel(auctionService, servingCache, "Read precomputed campaign/bid/ranking data", "Redis/Aerospike protocol")
Rel(targetingService, servingCache, "Read targeting rules and allow/block lists", "Redis/Aerospike protocol")
Rel(budgetService, budgetCache, "Atomic counters, reservation, pacing state", "Redis/Aerospike protocol")
Rel(creativeService, servingCache, "Read creative metadata and status", "Redis/Aerospike protocol")
Rel(userProfileService, userProfileStore, "Read/update profile and frequency caps", "Aerospike/Redis protocol")

