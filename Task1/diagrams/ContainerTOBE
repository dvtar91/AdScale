' Внешние связи
' =========================================================
Rel(dspPartner1, globalTrafficManager, "Bid requests / responses", "HTTPS / OpenRTB")
Rel(dspPartnerN, globalTrafficManager, "Bid requests / responses", "HTTPS / OpenRTB")
Rel(endUser, globalTrafficManager, "Ad markup, impression/click/conversion events", "HTTPS")
Rel(advertiser, globalTrafficManager, "Работа в личном кабинете", "HTTPS")

Rel(globalTrafficManager, apiGateway, "Routes to nearest healthy region", "HTTPS")
Rel(apiGateway, rtbGateway, "RTB traffic", "HTTPS / gRPC")
Rel(apiGateway, trackingGateway, "Tracking events", "HTTPS")
Rel(apiGateway, advertiserWeb, "Static UI / Web App", "HTTPS")
Rel(apiGateway, campaignService, "Campaign management API", "REST / gRPC")
Rel(apiGateway, accountService, "Auth/account API", "REST / gRPC")
Rel(apiGateway, financeService, "Finance API", "REST / gRPC")
Rel(apiGateway, reportingApi, "Reports API", "REST / gRPC")

Rel(financeService, paymentGateway, "Payments / refunds / confirmations", "HTTPS / REST")
Rel(fraudService, fraudProvider, "Reputation feeds / external checks", "HTTPS / Batch API")

