@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_LEFT_RIGHT()

title C4 Container Diagram — AdScale Target Architecture in 1 Year

' =========================================================
' Акторы и внешние системы
' =========================================================
Person(advertiser, "Рекламодатель", "Управляет кампаниями, бюджетами, ставками и отчётами")
Person_Ext(endUser, "Пользователь сайта/приложения", "Видит рекламу, генерирует показы и клики")

System_Ext(dspPartner1, "DSP-партнёр #1", "Bid requests / bid responses по OpenRTB")
System_Ext(dspPartnerN, "DSP-партнёры", "Мультиплатформенные интеграции по OpenRTB")
System_Ext(paymentGateway, "Платёжный шлюз", "Пополнение рекламных бюджетов")
System_Ext(fraudProvider, "External Fraud / Reputation Provider", "Внешние сигналы антифрода, reputation feeds")

' =========================================================
' Edge / Multi-region routing
' =========================================================
System_Boundary(edge, "Edge / Global Traffic Layer") {
    Container(globalTrafficManager, "Global Traffic Manager", "GeoDNS / Anycast / Cloud LB", "Маршрутизирует трафик между регионами, обеспечивает failover и latency-based routing")
    Container(apiGateway, "API Gateway / Edge Gateway", "Envoy / Kong / Nginx", "TLS termination, auth, rate limiting, quotas, request routing, partner-specific policies")
    Container(rtbGateway, "RTB Gateway", "Go / C++", "Принимает OpenRTB bid requests, валидирует, нормализует, применяет deadline budget и передаёт в Auction Service") <<Critical Path>>
    Container(trackingGateway, "Tracking Gateway", "Go", "Принимает impression/click/conversion events и публикует их в event bus") <<High Throughput>>
}

' =========================================================
' Core RTB микросервисы
' =========================================================
System_Boundary(rtbCore, "RTB Core Services — latency-critical") {

    Container(auctionService, "Auction Service", "C++ / Go", "Выбор победителя аукциона, применение bidding rules, pacing, ranking. Не выполняет тяжёлые DB-запросы в hot path") <<Critical Path>>

    Container(targetingService, "Targeting Service", "Go / C++", "Оценка условий таргетинга: geo, device, app/site, segments, allow/block lists") <<Critical Path>>

    Container(budgetService, "Budget Service", "Go", "Проверка доступности бюджета, reserved spend, pacing limits, защита от overspend") <<Critical Path>>

    Container(creativeService, "Creative Service", "Go / Node.js", "Выбор и валидация креативов, metadata, creative policy checks")

    Container(responseBuilder, "Response Builder", "Go / Node.js", "Формирует OpenRTB bid response, HTML/JS/VAST/Native markup") <<Critical Path>>

    Container(userProfileService, "User Profile Service", "Go", "Чтение low-latency профиля пользователя, сегментов и frequency capping")
}

' =========================================================
' Campaign Management / Backoffice микросервисы
' =========================================================
System_Boundary(backoffice, "Campaign Management & Backoffice Services") {

    Container(advertiserWeb, "Advertiser Web App", "React / TypeScript", "Личный кабинет рекламодателя")

    Container(campaignService, "Campaign Service", "Go / Java / Node.js", "CRUD кампаний, групп объявлений, ставок, статусов и targeting-ссылок")

    Container(accountService, "Account Service", "Go / Java", "Пользователи, организации, роли, права доступа, API tokens")

    Container(financeService, "Finance Service", "Go / Java", "Платежи, балансы, инвойсы, финансовые транзакции, reconciliation")

    Container(reportingApi, "Reporting API", "Go / Python", "API отчётности для кабинета и внешних клиентов")

    Container(notificationService, "Notification Service", "Go / Node.js", "Email/webhook/Slack-уведомления о лимитах, ошибках, статусах кампаний")
}

' =========================================================
' Data / Streaming / Processing
' =========================================================
System_Boundary(dataPlatform, "Event-driven Data Platform") {

    ContainerQueue(eventBus, "Kafka / Redpanda Cluster", "Event Streaming", "Центральная шина событий: bid, impression, click, conversion, billing, campaign changes") <<Critical Infrastructure>>

    Container(streamProcessor, "Stream Processing", "Flink / Kafka Streams", "Агрегации в near real-time, расчёт статистики, enrichment, fraud signals, spending updates")

    Container(statsService, "Statistics Service", "Go / Python", "Подготовка агрегатов по показам, кликам, расходам, win-rate, CTR, eCPM")

    Container(billingWorker, "Billing Worker", "Go", "Асинхронное списание средств по billable events, идемпотентная обработка, сверка с Finance Service")

    Container(fraudService, "Fraud Detection Service", "Python / Go", "Выявление подозрительных кликов/показов, scoring, блокировки источников")

    Container(mlOptimizationService, "ML / Optimization Service", "Python", "Оптимизация ставок, прогноз CTR/CVR, рекомендации для кампаний")
}

' =========================================================
' Serving cache / low-latency stores
' =========================================================
System_Boundary(servingData, "Serving Data Layer — low latency") {

    ContainerDb(servingCache, "Serving Cache", "Redis Cluster / Aerospike", "Активные кампании, ставки, таргетинги, лимиты, креативы, precomputed decision data") <<Critical Path>>

    ContainerDb(budgetCache, "Budget Counters Store", "Redis Cluster / Aerospike", "Atomic counters, reserved budget, pacing state, frequency counters") <<Critical Path>>

    Container(cachePublisher, "Serving Data Publisher", "Go", "Собирает изменения из campaign/budget/creative services и публикует optimized snapshots в Serving Cache")

    ContainerDb(userProfileStore, "User Profile Store", "Aerospike / Redis Cluster", "Профили пользователей, сегменты, frequency capping, low-latency lookup") <<Critical Path>>
}

' =========================================================
' Databases per service
' =========================================================
System_Boundary(databases, "Service-owned Databases") {

    ContainerDb(campaignDb, "Campaign DB", "PostgreSQL", "Владение Campaign Service: кампании, ad groups, targeting refs, ставки, статусы")

    ContainerDb(accountDb, "Account DB", "PostgreSQL", "Владение Account Service: пользователи, организации, роли, permissions, API keys")

    ContainerDb(financeDb, "Finance DB", "PostgreSQL", "Владение Finance Service: ledger, payments, invoices, balances, financial audit")

    ContainerDb(creativeDb, "Creative DB", "PostgreSQL / Object Storage metadata", "Владение Creative Service: metadata, moderation status, creative references")

    ContainerDb(statsDb, "Statistics DB", "ClickHouse", "Агрегированная статистика, time-series OLAP, отчёты")

    ContainerDb(analyticsDb, "Analytics Data Lake / Warehouse", "S3/GCS + ClickHouse", "Долгосрочное хранение событий, аналитика, ML datasets")

    ContainerDb(fraudDb, "Fraud DB", "ClickHouse / PostgreSQL", "Fraud scores, blocklists, suspicious sources, investigation data")

    ContainerDb(mlFeatureStore, "Feature Store", "Feast / Redis / Object Storage", "Фичи для ML-моделей, offline/online features")
}

' =========================================================
' Observability / Platform
' =========================================================
System_Boundary(platform, "Platform & Observability") {

    Container(k8s, "Kubernetes Platform", "Kubernetes", "Оркестрация сервисов, autoscaling, rolling/canary deployments")

    Container(serviceMesh, "Service Mesh", "Istio / Linkerd / Envoy", "mTLS, retries, circuit breakers, traffic shaping, telemetry")

    Container(prometheus, "Prometheus", "Metrics", "Сбор технических и бизнес-метрик")

    Container(grafana, "Grafana", "Dashboards", "SLO/SLA dashboards, latency, RPS, error rate, saturation")

    Container(tracing, "OpenTelemetry / Jaeger", "Distributed Tracing", "Трейсинг RTB-path и асинхронных потоков")

    Container(logs, "Loki / ELK", "Centralized Logs", "Централизованные логи сервисов")

    Container(secrets, "Secrets Manager", "Vault / Cloud KMS", "Секреты, ключи DSP, credentials, certificates")
}

