Rel(responseBuilder, eventBus, "Publishes win/render metadata", "Kafka API / Async")
Rel(trackingGateway, eventBus, "Publishes impression/click/conversion events", "Kafka API / Async")

' =========================================================
' Campaign / backoffice interactions
' =========================================================
Rel(advertiserWeb, campaignService, "Manage campaigns, bids, targeting", "HTTPS / REST")
Rel(advertiserWeb, accountService, "Login, roles, organization settings", "HTTPS / REST")
Rel(advertiserWeb, financeService, "Balances, payments, invoices", "HTTPS / REST")
Rel(advertiserWeb, reportingApi, "View reports", "HTTPS / REST")

